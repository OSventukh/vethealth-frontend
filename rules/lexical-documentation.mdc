### Get Lexical Peer Dependency or Throw (TypeScript)

Source: https://lexical.dev/docs/api/modules/lexical_extension

Fetches the configuration and output of a Lexical extension by its name from an editor, throwing an error if not found. This function is designed for situations where you need to ensure an extension is present and configured, commonly used within node implementations when accessing extension-specific properties. It requires both the extension type and its name.

```typescript
import type { EmojiExtension } from "./EmojiExtension";
import { TextNode } from "lexical";
import { $getEditor } from "lexical";
import { addClassNamesToElement } from "@lexical/utils";
import { EditorConfig, LexicalEditor } from "lexical";

// Assuming EmojiExtension, TextNode, $getEditor, addClassNamesToElement, EditorConfig, LexicalEditor are defined

export class EmojiNode extends TextNode {
  // other implementation details not included
  createDOM(
    config: EditorConfig,
    editor?: LexicalEditor | undefined
  ): HTMLElement {
    const dom = super.createDOM(config, editor);
    addClassNamesToElement(
      dom,
      getPeerDependencyFromEditorOrThrow<typeof EmojiExtension>(
        editor || $getEditor(),
        "@lexical/playground/emoji"
      ).config.emojiClass
    );
    return dom;
  }
}
```

