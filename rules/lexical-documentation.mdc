### Extend DecoratorNode: Video Player Node

Source: https://lexical.dev/docs/concepts/nodes

This example illustrates extending Lexical's DecoratorNode to embed a video player. It defines the node type, cloning, constructor, and DOM creation/update methods. The crucial `decorate` method returns a React component (`VideoPlayer`) to render the video. Helper functions are included for creating and identifying video nodes.

```typescript
import {DecoratorNode, LexicalNode, NodeKey} from 'lexical';
import React from 'react';

// Assuming VideoPlayer is a React component defined elsewhere
const VideoPlayer = ({ videoID }: { videoID: string }) => <div>Video Player: {videoID}</div>;

export class VideoNode extends DecoratorNode<React.ReactNode> {
  __id: string;

  static getType(): string {
    return 'video';
  }

  static clone(node: VideoNode): VideoNode {
    return new VideoNode(node.__id, node.__key);
  }

  constructor(id: string, key?: NodeKey) {
    super(key);
    this.__id = id;
  }

  createDOM(): HTMLElement {
    return document.createElement('div');
  }

  updateDOM(): false {
    return false;
  }

  decorate(): React.ReactNode {
    return <VideoPlayer videoID={this.__id} />;
  }
}

export function $createVideoNode(id: string): VideoNode {
  return $applyNodeReplacement(new VideoNode(id));
}

export function $isVideoNode(
  node: LexicalNode | null | undefined,
): node is VideoNode {
  return node instanceof VideoNode;
}
```

