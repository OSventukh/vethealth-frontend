### Use Lexical Subscription Hook in React

Source: https://lexical.dev/docs/api/modules/lexical_react_useLexicalSubscription

The `useLexicalSubscription` hook from `@lexical/react` allows you to subscribe to Lexical editor state changes for rendering. It accepts a stable subscription factory function that defines how to get the initial value and how to subscribe to updates. The hook returns the current value of the subscription, which is of type `T`.

```typescript
import { useLexicalSubscription, LexicalSubscription } from '@lexical/react/useLexicalSubscription';
import { EditorState, LexicalEditor } from 'lexical';

function useMySubscription<T>(editor: LexicalEditor, initialValue: T, subscribeFn: (editor: LexicalEditor) => (editorState: EditorState) => void): T {
  const subscription: LexicalSubscription<T> = {
    initialValueFn: () => initialValue,
    subscribe: (callback) => {
      const unsubscribe = subscribeFn(editor)((editorState) => {
        const value = editorState.readRoot(); // Example: read some value from editor state
        callback(value);
      });
      return unsubscribe;
    }
  };

  const value = useLexicalSubscription(editor, () => subscription);
  return value;
}
```

