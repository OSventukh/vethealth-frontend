### Create Bootstrapped Yjs Document for Lexical

Source: https://lexical.dev/docs/collaboration/react

A utility function to create a Yjs document with initial Lexical editor content, intended for server-side bootstrapping to prevent race conditions during client connections.

```javascript
import type {CreateEditorArgs} from 'lexical';  
  
import {$getRoot, $createParagraphNode} from 'lexical';  
import {Doc} from 'yjs';  
  
import {withHeadlessCollaborationEditor} from './withHeadlessCollaborationEditor';  
  
function createBootstrappedYDoc(nodes: CreateEditorArgs['nodes']): Doc {  
  return withHeadlessCollaborationEditor(nodes, (editor) => {  
    const yDoc = new Doc();  
    editor.update(() => {  
      $getRoot().append($createParagraphNode());  
    }, {discrete: true});  
    return yDoc;  
  });  
}  

```

